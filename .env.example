# ============================================================
# TontineChain Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS COMMITER .env dans git
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME=TontineChain
APP_URL=https://api.tontinechain.io
API_PREFIX=api/v1

# --- Base de données PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=tontinechain
DB_PASS=supersecretpassword
DB_NAME=tontinechain_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT RS256 (chemins vers les fichiers PEM) ---
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- Blockchain Polygon ---
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_NETWORK=polygon-mumbai
BACKEND_WALLET_PRIVATE_KEY=0xyour_backend_wallet_private_key_here
REGISTRY_CONTRACT_ADDRESS=0x_address_du_TontineRegistry_deployé

# --- Wallets custodial ---
WALLET_ENCRYPTION_KEY=une_cle_aes256_de_32_caracteres_minimum

# --- CinetPay (paiements Mobile Money) ---
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_SECRET=your_cinetpay_secret
CINETPAY_WEBHOOK_SECRET=your_webhook_secret_hmac
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2

# --- Notifications ---
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# --- Throttle / Rate limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Logs ---
LOG_LEVEL=debug


TWILIO_ACCOUNT_SID=ton_account_sid_ici
TWILIO_AUTH_TOKEN=ton_auth_token_ici
TWILIO_PHONE_NUMBER=+1234567890 # Le numéro d'expéditeur Twilio
